# ============================================================
# Jarvis — переменные окружения
# Скопируй этот файл в .env и заполни нужные ключи.
# .env в .gitignore, поэтому ключи не попадут в git.
# ============================================================

# --- LLM brain ---
# Достаточно ОДНОГО ключа в зависимости от brain.engine в config.yaml.

# AIHubMix — OpenAI-совместимый агрегатор. Бесплатные модели (gpt-5.5-free и др.).
# Используется также vision-скиллом analyze_screen.
# Дашборд: https://aihubmix.com/models
AIHUBMIX_API_KEY=

# Mistral La Plateforme — free tier работает глобально, поддерживает tool calling.
# Получить: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=

# Google AI Studio (Gemini) — НЕДОСТУПЕН в РУ/KG.
# Получить: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# --- TTS премиум (опционально, если tts.engine=elevenlabs) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
